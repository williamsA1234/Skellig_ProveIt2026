{
  "profileName": "AI_V1",
  "version": "1.0.0",
  "description": "Analog input instrument profile with four-level limit alarms and bad quality detection. Used for read-only analog measurements (e.g., temperature, pressure, level sensors) where no output or digital I/O is required.",
  "applicableTo": "Instruments with analog measurement feedback only (AI)",
  "ignitionUdtSource": "Core/AI",
  "Device_Core": {
    "description": "Equipment identity and context metadata",
    "attributes": [
      {
        "name": "TagName",
        "dataType": "opc:String",
        "nodeId": "i=12",
        "description": "ISA-5.1 instrument tag identifier (e.g., TI-250-001)"
      },
      {
        "name": "ShortName",
        "dataType": "opc:String",
        "nodeId": "i=12",
        "description": "Human-readable equipment name used in UNS topic path"
      },
      {
        "name": "ProfileDefinition",
        "dataType": "opc:String",
        "nodeId": "i=12",
        "description": "URL to the SM Profile definition that this instance conforms to"
      },
      {
        "name": "Description",
        "dataType": "opc:String",
        "nodeId": "i=12",
        "description": "Free-text description of the equipment instance"
      },
      {
        "name": "Area",
        "dataType": "opc:String",
        "nodeId": "i=12",
        "description": "ISA-95 area designation (e.g., Cell_Culture)"
      },
      {
        "name": "Unit",
        "dataType": "opc:String",
        "nodeId": "i=12",
        "description": "ISA-95 unit designation (e.g., SUB-250)"
      }
    ]
  },
  "IO": {
    "description": "Process I/O - single analog input bound to field instrument via MQTT",
    "attributes": [
      {
        "name": "AI_Feedback",
        "dataType": "opc:Double",
        "nodeId": "i=11",
        "description": "Measured process variable from field instrument",
        "engUnit": "per-instance",
        "accessLevel": "Read"
      }
    ]
  },
  "Parameters": {
    "description": "Configurable parameters for alarm setpoints, output clamps, and alarm enables",
    "attributes": [
      {
        "name": "High_High_Sp",
        "dataType": "opc:Float",
        "nodeId": "i=10",
        "description": "High-High alarm setpoint for AI_Feedback",
        "defaultValue": 100.0
      },
      {
        "name": "High_Sp",
        "dataType": "opc:Float",
        "nodeId": "i=10",
        "description": "High alarm setpoint for AI_Feedback",
        "defaultValue": 90.0
      },
      {
        "name": "Low_Sp",
        "dataType": "opc:Float",
        "nodeId": "i=10",
        "description": "Low alarm setpoint for AI_Feedback",
        "defaultValue": 10.0
      },
      {
        "name": "Low_Low_Sp",
        "dataType": "opc:Float",
        "nodeId": "i=10",
        "description": "Low-Low alarm setpoint for AI_Feedback",
        "defaultValue": 5.0
      },
      {
        "name": "High_High_Enab",
        "dataType": "opc:Boolean",
        "nodeId": "i=1",
        "description": "Enable/disable High-High limit alarm",
        "defaultValue": false
      },
      {
        "name": "High_Enab",
        "dataType": "opc:Boolean",
        "nodeId": "i=1",
        "description": "Enable/disable High limit alarm",
        "defaultValue": false
      },
      {
        "name": "Low_Enab",
        "dataType": "opc:Boolean",
        "nodeId": "i=1",
        "description": "Enable/disable Low limit alarm",
        "defaultValue": false
      },
      {
        "name": "Low_Low_Enab",
        "dataType": "opc:Boolean",
        "nodeId": "i=1",
        "description": "Enable/disable Low-Low limit alarm",
        "defaultValue": false
      },
      {
        "name": "Out_Min",
        "dataType": "opc:Float",
        "nodeId": "i=10",
        "description": "Minimum output clamp value",
        "defaultValue": 0.0
      },
      {
        "name": "Out_Max",
        "dataType": "opc:Float",
        "nodeId": "i=10",
        "description": "Maximum output clamp value",
        "defaultValue": 100.0
      },
      {
        "name": "AI_Bad_Alarm_Enab",
        "dataType": "opc:Boolean",
        "nodeId": "i=1",
        "description": "Enable/disable bad quality alarm on analog input",
        "defaultValue": false
      },
      {
        "name": "Operator",
        "dataType": "opc:Boolean",
        "nodeId": "i=1",
        "description": "Operator acknowledgment or manual override flag",
        "defaultValue": false
      },
      {
        "name": "Maintenance",
        "dataType": "opc:Boolean",
        "nodeId": "i=1",
        "description": "Equipment is in maintenance mode",
        "defaultValue": false
      },
      {
        "name": "OOS",
        "dataType": "opc:Boolean",
        "nodeId": "i=1",
        "description": "Equipment is out of service",
        "defaultValue": false
      }
    ]
  },
  "Alarms": {
    "description": "Reference tags for Ignition alarm evaluation. Each tag's value mirrors an IO process variable that an Ignition alarm property evaluates against. Alarm active/inactive state is not published in this profile version.",
    "attributes": [
      {
        "name": "High_High",
        "dataType": "opc:Float",
        "sourceTag": "IO.AI_Feedback",
        "description": "Reference tag evaluating to AI_Feedback PV for Ignition alarm evaluation",
        "ignitionAlarm": {
          "mode": "AboveValue",
          "priority": "High",
          "setpoint": "Parameters.High_High_Sp",
          "enabledBy": "Parameters.High_High_Enab"
        }
      },
      {
        "name": "High",
        "dataType": "opc:Float",
        "sourceTag": "IO.AI_Feedback",
        "description": "Reference tag evaluating to AI_Feedback PV for Ignition alarm evaluation",
        "ignitionAlarm": {
          "mode": "AboveValue",
          "priority": "Low",
          "setpoint": "Parameters.High_Sp",
          "enabledBy": "Parameters.High_Enab"
        }
      },
      {
        "name": "Low",
        "dataType": "opc:Float",
        "sourceTag": "IO.AI_Feedback",
        "description": "Reference tag evaluating to AI_Feedback PV for Ignition alarm evaluation",
        "ignitionAlarm": {
          "mode": "BelowValue",
          "priority": "Low",
          "setpoint": "Parameters.Low_Sp",
          "enabledBy": "Parameters.Low_Enab"
        }
      },
      {
        "name": "Low_Low",
        "dataType": "opc:Float",
        "sourceTag": "IO.AI_Feedback",
        "description": "Reference tag evaluating to AI_Feedback PV for Ignition alarm evaluation",
        "ignitionAlarm": {
          "mode": "BelowValue",
          "priority": "High",
          "setpoint": "Parameters.Low_Low_Sp",
          "enabledBy": "Parameters.Low_Low_Enab"
        }
      },
      {
        "name": "AI_Bad_Quality",
        "dataType": "opc:Float",
        "sourceTag": "IO.AI_Feedback",
        "description": "Reference tag evaluating to AI_Feedback PV for Ignition bad quality alarm evaluation",
        "ignitionAlarm": {
          "mode": "BadQuality",
          "priority": "High",
          "enabledBy": "Parameters.AI_Bad_Alarm_Enab"
        }
      }
    ]
  }
}
